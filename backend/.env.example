# Aiven MySQL / any MySQL credentials
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=3306
DB_USER=avnadmin
DB_PASSWORD=your_password
DB_NAME=defaultdb

# SSL — path to Aiven CA certificate file (download from Aiven dashboard)
DB_SSL_CA=

# Flask settings
FLASK_ENV=production

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-key-change-in-production

# AI model version
MODEL_VERSION=v3_3datasets

# Gemini API key (if used)
GEMINI_API_KEY=
